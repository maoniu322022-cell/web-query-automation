import logging
import time
from concurrent.futures import ThreadPoolExecutor, as_completed
from scraper import PeopleSearchNowScraper
from data_handler import DataHandler, results_lock

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s'
)

logger = logging.getLogger(__name__)

# 骞跺彂鏁帮紙鍚屾椂寮€鍚殑娴忚鍣ㄦ暟锛?max_workers=1  # 寤鸿 2-4 涓紝鏍规嵁鐢佃剳閰嶇疆璋冩暣

def search_worker(phone: str, worker_id: int, total: int) -> dict:
    """
    鍗曚釜绾跨▼鐨勫伐浣滃嚱鏁?    """
    try:
        scraper = PeopleSearchNowScraper()
        logger.info(f"[Worker {worker_id}] 寮€濮嬫煡璇? {phone}")
        result = scraper.search_by_phone(phone)
        scraper.close()
        
        if result:
            logger.info(f"[Worker {worker_id}] 鉁?鎵惧埌缁撴灉: {phone}")
            return result
        else:
            logger.info(f"[Worker {worker_id}] 鉁?鏈壘鍒扮粨鏋? {phone}")
            return None
    except Exception as e:
        logger.error(f"[Worker {worker_id}] 鏌ヨ澶辫触 {phone}: {e}")
        return None

def main():
    logger.info("=" * 60)
    logger.info(f"寮€濮?People Search Now 鍙嶅悜鏌ヨ (澶氱嚎绋嬫ā寮? {MAX_WORKERS} 涓苟鍙?")
    logger.info("=" * 60)
    
    handler = DataHandler()
    phones = handler.load_phones("phones.txt")
    
    if not phones:
        logger.error("No phones found!")
        return
    
    logger.info(f"读取了 {len(phones)} 个电话号码")
    logger.info(f"将使用 {MAX_WORKERS} 个线程并发查询")
    logger.info("")
    
    results = []
    completed_count = 0
    
    try:
        # 浣跨敤绾跨▼姹犳墽琛屽櫒
        with ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:
            # 鎻愪氦鎵€鏈変换鍔?            future_to_phone = {
                executor.submit(search_worker, phone, i % MAX_WORKERS + 1, len(phones)): phone 
                for i, phone in enumerate(phones)
            }
            
            # 澶勭悊瀹屾垚鐨勪换鍔?            for future in as_completed(future_to_phone):
                phone = future_to_phone[future]
                completed_count += 1
                
                try:
                    result = future.result()
                    if result:
                        with results_lock:
                            results.append(result)
                    logger.info(f"[杩涘害] {completed_count}/{len(phones)} 宸插畬鎴?)
                except Exception as e:
                    logger.error(f"浠诲姟鎵ц鍑洪敊 {phone}: {e}")
    
    except KeyboardInterrupt:
        logger.warning("鐢ㄦ埛涓鏌ヨ")
    
    logger.info("")
    logger.info("=" * 60)
    
    if results:
        logger.info(f"鉁?鎴愬姛鎵惧埌 {len(results)} 涓粨鏋?)
        logger.info(f"鉁?鎴愬姛鐜? {len(results)}/{len(phones)} = {len(results)*100//len(phones)}%")
        logger.info(f"鉁?淇濆瓨鍒?search_results.xlsx")
        handler.save_results(results, "search_results.xlsx")
    else:
        logger.info("鏈壘鍒颁换浣曠粨鏋?)

if __name__ == "__main__":
    main()

